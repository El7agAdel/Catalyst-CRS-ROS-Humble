<?xml version="1.0"?>
<robot name="camera_rig">

  <!-- Simple materials for RViz/URDF -->
  <material name="DarkGray"><color rgba="0.25 0.25 0.25 1"/></material>
  <material name="Black"><color rgba="0.05 0.05 0.05 1"/></material>
  <material name="Glass"><color rgba="0.20 0.35 0.50 0.6"/></material>

  <link name="camera_base">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>

    <visual>
      <geometry><box size="0.04 0.04 0.03"/></geometry>
      <material name="DarkGray"/>
    </visual>
    <collision>
      <geometry><box size="0.04 0.04 0.03"/></geometry>
    </collision>
  </link>

  <!-- Left stereo camera housing + lens -->
  <link name="camera_left_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="2e-6" ixy="0" ixz="0" iyy="2e-6" iyz="0" izz="2e-6"/>
    </inertial>

    <!-- Housing -->
    <visual>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.02"/></geometry>
      <material name="Black"/>
    </visual>
    <collision>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.02"/></geometry>
    </collision>

    <!-- Lens (cylinders are Z-axis by default, so rotate to face +X) -->
    <visual>
      <origin xyz="0.027 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.006" length="0.008"/></geometry>
      <material name="Glass"/>
    </visual>
  </link>

  <!-- Right stereo camera housing + lens -->
  <link name="camera_right_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="2e-6" ixy="0" ixz="0" iyy="2e-6" iyz="0" izz="2e-6"/>
    </inertial>

    <visual>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.02"/></geometry>
      <material name="Black"/>
    </visual>
    <collision>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.02"/></geometry>
    </collision>

    <visual>
      <origin xyz="0.027 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.006" length="0.008"/></geometry>
      <material name="Glass"/>
    </visual>
  </link>

  <joint name="left_joint" type="fixed">
    <parent link="camera_base"/>
    <child link="camera_left_link"/>
    <origin xyz="0 0.03 0" rpy="0 0 0"/>
  </joint>

  <joint name="right_joint" type="fixed">
    <parent link="camera_base"/>
    <child link="camera_right_link"/>
    <origin xyz="0 -0.03 0" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo sensors (unchanged) -->
  <gazebo reference="camera_base">
    <sensor name="rgb_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <topic>/cam/rgb/image_raw</topic>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image><width>1280</width><height>720</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>10.0</far></clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo reference="camera_base">
    <sensor name="depth_camera" type="depth_camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <topic>/cam/depth/image_raw</topic>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.1</near><far>5.0</far></clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo reference="camera_left_link">
    <sensor name="stereo_left" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <topic>/cam/stereo/left/image_raw</topic>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>10.0</far></clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo reference="camera_right_link">
    <sensor name="stereo_right" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <topic>/cam/stereo/right/image_raw</topic>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>10.0</far></clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo>
    <static>true</static>
  </gazebo>

</robot>
